{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Typst Desktop",
  "version": "0.1.0",
  "identifier": "com.typst-desktop.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Typst Desktop",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
